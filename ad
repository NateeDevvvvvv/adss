	THEME_ACCENT = c
	THEME_ACCENT_DIM = Color3.new(c.R * 0.65, c.G * 0.65, c.B * 0.65)
	THEME_ACCENT_BRIGHT = Color3.new(math.min(1, c.R + 0.35), math.min(1, c.G + 0.35), math.min(1, c.B + 0.25))
	for _, fn in ipairs(_themedCallbacks) do pcall(fn, c) end
end
